# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env

# R
.Rhistory
.RData
.Rproj.user/

# Data (默认不入库；replication 数据另行管理)
data/raw/
*.xlsx
*.csv
!docs/**/*.csv

# Outputs
outputs/
*.log

# Web UI uploads
web_uploads/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Claude Code 本地状态/运行时（机器相关，不入库；仅保留共享的 settings.json + 项目工具）
.claude/*
!.claude/settings.json
# 共享项目工具：推断双审子代理 + 加分析脚手架技能（settings.local.json 仍不入库，含机器相关 bypass/allow）
!.claude/agents/
!.claude/skills/

# Skill ingestion 工作区（原件不入库，登记结果入 docs/）
skills_inbox/_processed/
skills_inbox/*.zip

# 自我进化发现的候选队列（运行时生成的 backlog，按需 --persist，不入库）
researchforge/catalog/candidate_queue/discovered.yaml

# AI scratch test logs (never commit) — write scratch output to %TEMP% instead
*log.txt
*log*.txt
v[0-9]*.txt
