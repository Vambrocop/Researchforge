{
  "permissions": {
    "allow": [
      "Bash(git --no-pager grep -n \"# compute\" -- researchforge/executor/run.py)",
      "Bash(git --no-pager grep -n \"code += \\\\[\" -- researchforge/executor/run.py)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git push --quiet 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Auto-pushing to GitHub..."
          }
        ]
      }
    ]
  }
}
